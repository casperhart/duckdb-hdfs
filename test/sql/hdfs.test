# name: test/sql/hdfs.test
# description: Integration tests for the hdfs extension against a real HDFS.
# group: [sql]

#
# These tests require a running HDFS cluster (see test/docker) and the host-side
# client config on HADOOP_CONF_DIR. The easiest way to run them:
#
#     make                              # build the extension + duckdb
#     test/scripts/run_hdfs_tests.sh    # up -> run -> down
#
# They are skipped unless HDFS_TEST_RUNNING is set, so `make test` stays green
# without docker.

require hdfs

require parquet

require-env HDFS_TEST_RUNNING

# The effective user comes from the Hadoop environment (HADOOP_USER_NAME here,
# set by run_hdfs_tests.sh) so writes to the hadoop-owned /test are permitted.

# --- reading CSV over hdfs:// ------------------------------------------------

query I
SELECT count(*) FROM read_csv('hdfs://localhost:9000/test/data.csv');
----
3

query IT
SELECT id, name FROM read_csv('hdfs://localhost:9000/test/data.csv') ORDER BY id;
----
1	alice
2	bob
3	carol

# --- reading Parquet over hdfs:// --------------------------------------------

query I
SELECT count(*) FROM read_parquet('hdfs://localhost:9000/test/data.parquet');
----
5

query IT
SELECT id, name FROM read_parquet('hdfs://localhost:9000/test/data.parquet') ORDER BY id LIMIT 1;
----
0	v0

# --- globbing ----------------------------------------------------------------

# Wildcard against the two seeded fixtures (data.csv + data.parquet). Patterned
# on "data.*" so it stays deterministic even if other files are written below.
query I
SELECT count(*) FROM glob('hdfs://localhost:9000/test/data.*');
----
2

# A single '*' matches one path level only (not the nested/ subdirectory).
query I
SELECT count(*) FROM glob('hdfs://localhost:9000/test/*.parquet');
----
1

# A bare '*' matches the two top-level files plus the nested/ directory, but
# directories are filtered out of glob results (so readers never try to open a
# directory as a data file). Run before any writes so the count is stable.
query I
SELECT count(*) FROM glob('hdfs://localhost:9000/test/*');
----
2

# '**' crawls the subtree (matching zero or more levels, like DuckDB's local
# globber): the two top-level files plus nested/more.parquet.
query I
SELECT count(*) FROM glob('hdfs://localhost:9000/test/**');
----
3

query I
SELECT count(*) FROM glob('hdfs://localhost:9000/test/**/*.parquet');
----
2

# Reading a glob pattern directly expands to the matching files.
query I
SELECT count(*) FROM read_csv('hdfs://localhost:9000/test/data*.csv');
----
3

# --- metadata functions: hdfs_ls / hdfs_glob / hdfs_stat / hdfs_exists --------
# Run before any writes so /test holds exactly data.csv, data.parquet, nested/
# (and nested/ holds more.parquet).

# hdfs_ls lists a directory's immediate children, directories included (unlike
# glob(), which drops them).
query TT
SELECT name, type FROM hdfs_ls('hdfs://localhost:9000/test') ORDER BY name;
----
data.csv	file
data.parquet	file
nested	directory

# The path column carries the authority back as a full hdfs:// URL.
query T
SELECT path FROM hdfs_ls('hdfs://localhost:9000/test') WHERE name = 'nested';
----
hdfs://localhost:9000/test/nested

# Full metadata is populated: owner non-empty and permissions are 9 chars.
query I
SELECT count(*) FROM hdfs_ls('hdfs://localhost:9000/test')
WHERE length(owner) > 0 AND length(permissions) = 9;
----
3

# Files carry replication / block_size; directories report them as NULL.
query I
SELECT count(*) FROM hdfs_ls('hdfs://localhost:9000/test')
WHERE name = 'data.csv' AND replication >= 1 AND block_size > 0;
----
1

query I
SELECT count(*) FROM hdfs_ls('hdfs://localhost:9000/test')
WHERE name = 'nested' AND replication IS NULL AND block_size IS NULL;
----
1

# A terminal '**' crawls the subtree (nested/ holds more.parquet at this
# point) and yields the nested directory entry itself too — the replacement
# for the old recursive := true parameter.
query I
SELECT count(*) FROM hdfs_ls('hdfs://localhost:9000/test/**');
----
4

# hdfs_list_parallelism bounds the concurrent listing RPCs of a multi-directory
# walk, which streams entries as the background walk produces them. Row order
# is completion order (not guaranteed), so always ORDER BY here.
query T
SELECT current_setting('hdfs_list_parallelism');
----
16

statement ok
SET hdfs_list_parallelism = 1;

query T
SELECT name FROM hdfs_ls('hdfs://localhost:9000/test/**') ORDER BY name;
----
data.csv
data.parquet
more.parquet
nested

statement ok
SET hdfs_list_parallelism = 64;

query T
SELECT name FROM hdfs_ls('hdfs://localhost:9000/test/**') ORDER BY name;
----
data.csv
data.parquet
more.parquet
nested

statement ok
RESET hdfs_list_parallelism;

# --- glob patterns in hdfs_ls --------------------------------------------------

# A wildcard switches hdfs_ls to glob semantics: the matched entries themselves
# come back (files and directories both), without listing into matched dirs.
query TT
SELECT name, type FROM hdfs_ls('hdfs://localhost:9000/test/*') ORDER BY name;
----
data.csv	file
data.parquet	file
nested	directory

# '**' matches zero or more levels, so both parquet files match here.
query T
SELECT name FROM hdfs_ls('hdfs://localhost:9000/test/**/*.parquet') ORDER BY name;
----
data.parquet
more.parquet

# '?' matches exactly one character; character classes support ranges.
query T
SELECT name FROM hdfs_ls('hdfs://localhost:9000/test/data.c??') ORDER BY name;
----
data.csv

query TT
SELECT name, type FROM hdfs_ls('hdfs://localhost:9000/test/[a-n]*') ORDER BY name;
----
data.csv	file
data.parquet	file
nested	directory

# {a,b} alternation, including alternatives spanning a '/'.
query T
SELECT name FROM hdfs_ls('hdfs://localhost:9000/test/data.{csv,parquet}') ORDER BY name;
----
data.csv
data.parquet

query T
SELECT name FROM hdfs_ls('hdfs://localhost:9000/test/{data.csv,nested/more.parquet}') ORDER BY name;
----
data.csv
more.parquet

# A pattern matching nothing is an empty result, not an error.
query I
SELECT count(*) FROM hdfs_ls('hdfs://localhost:9000/test/zzz*');
----
0

# An invalid pattern errors at open.
statement error
SELECT * FROM hdfs_ls('hdfs://localhost:9000/test/**/a/**');
----
multiple '**'

# hdfs_glob is the same walk with pattern semantics always on.
query TT
SELECT name, type FROM hdfs_glob('hdfs://localhost:9000/test/*') ORDER BY name;
----
data.csv	file
data.parquet	file
nested	directory

# On a literal path, hdfs_glob returns the entry itself where hdfs_ls lists
# a directory's children.
query TT
SELECT name, type FROM hdfs_glob('hdfs://localhost:9000/test/nested');
----
nested	directory

# hdfs_stat returns exactly one row for a single path, file or directory.
query TT
SELECT name, type FROM hdfs_stat('hdfs://localhost:9000/test/nested');
----
nested	directory

query TT
SELECT name, type FROM hdfs_stat('hdfs://localhost:9000/test/data.parquet');
----
data.parquet	file

# Stat on a missing path errors.
statement error
SELECT * FROM hdfs_stat('hdfs://localhost:9000/test/does_not_exist');
----

# hdfs_exists is a scalar boolean predicate (true for files and directories).
query I
SELECT count(*) FROM range(1) WHERE hdfs_exists('hdfs://localhost:9000/test/data.csv');
----
1

query I
SELECT count(*) FROM range(1) WHERE hdfs_exists('hdfs://localhost:9000/test/nested');
----
1

query I
SELECT count(*) FROM range(1) WHERE hdfs_exists('hdfs://localhost:9000/test/does_not_exist');
----
0

# --- writing (COPY TO) then reading back -------------------------------------
# Writes go under nested/ so they can't perturb the /test/*.{csv,parquet} globs.

statement ok
COPY (SELECT 42 AS x, 'written' AS y) TO 'hdfs://localhost:9000/test/nested/written.parquet' (FORMAT parquet);

query IT
SELECT x, y FROM read_parquet('hdfs://localhost:9000/test/nested/written.parquet');
----
42	written

# Round-trip a larger relation through CSV.
statement ok
COPY (SELECT range AS n FROM range(1000)) TO 'hdfs://localhost:9000/test/nested/big.csv' (FORMAT csv, HEADER);

query II
SELECT count(*), sum(n) FROM read_csv('hdfs://localhost:9000/test/nested/big.csv');
----
1000	499500

# --- error handling ----------------------------------------------------------

# Opening a non-existent file surfaces a clear IO error.
statement error
SELECT * FROM read_csv('hdfs://localhost:9000/test/does_not_exist.csv');
----
